<style>
  .section-footer {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    transition: background-color var(--transition-base), border-color var(--transition-base);
  }

  .section-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  @media screen and (min-width: 768px) {
    .section-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .section-footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .section-footer__brand-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .section-footer__brand-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 320px;
  }

  .section-footer__heading {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .section-footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .section-footer__link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .section-footer__link:hover {
    color: var(--color-accent);
  }

  .section-footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  @media screen and (min-width: 768px) {
    .section-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .section-footer__copyright {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .section-footer__payment-icons {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .section-footer__payment-icon svg {
    width: 38px;
    height: 24px;
  }
</style>

<footer class="section-footer">
  <div class="page-width">
    <div class="section-footer__grid">
      {%- comment -%} Brand column {%- endcomment -%}
      <div class="section-footer__col">
        <p class="section-footer__brand-name">{{ shop.name }}</p>
        {%- if section.settings.footer_description != blank -%}
          <p class="section-footer__brand-text">{{ section.settings.footer_description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Link columns via blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="section-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4 class="section-footer__heading">{{ block.settings.heading }}</h4>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="section-footer__links">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="section-footer__link">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="section-footer__bottom">
      <p class="section-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ 'sections.footer.rights' | t }}
        {{ powered_by_link }}
      </p>

      {%- if section.settings.show_payment_icons -%}
        <div class="section-footer__payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            <span class="section-footer__payment-icon">
              {{ type | payment_type_svg_tag }}
            </span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer-wrapper",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_description",
      "default": "Luxury goods curated for the modern connoisseur. Worldwide shipping available.",
      "label": "t:sections.footer.settings.footer_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "default": true,
      "label": "t:sections.footer.settings.show_payment_icons.label"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "t:sections.footer.presets.name",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" }
      ]
    }
  ]
}
{% endschema %}
