{{ 'section-product-grid.css' | asset_url | stylesheet_tag }}

<section class="section-spacing">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="product-grid-section__header">
        <h2 class="product-grid-section__title">{{ 'sections.featured_collection.defaults.title' | t | default: section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="product-grid-section__subtitle">{{ 'sections.featured_collection.defaults.subtitle' | t | default: section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- liquid
      assign collection = section.settings.collection
      assign products_to_show = section.settings.products_to_show
      assign columns = section.settings.columns_desktop
    -%}

    <div class="product-grid {% if columns == 4 %}product-grid--4col{% endif %}">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card',
            card_product: product,
            show_secondary_image: true,
            lazy_load: true
          %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          {% render 'product-card', card_product: blank %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      <div style="text-align: center;">
        <a href="{{ collection.url }}" class="product-grid-section__view-all">
          {{ 'sections.featured_collection.view_all' | t }}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "t:sections.featured_collection.defaults.title",
      "label": "t:sections.featured_collection.settings.title.label"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.featured_collection.settings.subtitle.label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "t:sections.featured_collection.settings.products_to_show.label"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4",
      "label": "t:sections.featured_collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured_collection.settings.show_view_all.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.presets.name"
    }
  ]
}
{% endschema %}
