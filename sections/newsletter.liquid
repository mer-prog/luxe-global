<style>
  .section-newsletter {
    background-color: var(--color-text);
    color: var(--color-bg);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  [data-theme="dark"] .section-newsletter {
    background-color: #111111;
    color: #F5F5F5;
  }

  .section-newsletter__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .section-newsletter__heading {
    font-family: var(--font-heading);
  }

  .section-newsletter__text {
    font-size: 0.9375rem;
    opacity: 0.8;
    line-height: 1.7;
  }

  .section-newsletter__form {
    display: flex;
    width: 100%;
    max-width: 480px;
    margin-top: var(--space-sm);
  }

  .section-newsletter__input {
    flex: 1;
    min-height: var(--touch-target);
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: inherit;
    outline: none;
  }

  .section-newsletter__input::placeholder {
    color: inherit;
    opacity: 0.5;
  }

  .section-newsletter__input:focus {
    border-color: var(--color-accent);
  }

  .section-newsletter__submit {
    min-height: var(--touch-target);
    padding: 0.75rem 1.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background-color: var(--color-accent);
    color: #FFFFFF;
    border: 1px solid var(--color-accent);
    cursor: pointer;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
  }

  .section-newsletter__submit:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  @media screen and (max-width: 639px) {
    .section-newsletter__form {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>

<section class="section-newsletter section-spacing">
  <div class="page-width">
    <div class="section-newsletter__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="section-newsletter__text">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'section-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="section-newsletter__input"
          placeholder="{{ 'sections.newsletter.email_placeholder' | t }}"
          required
          autocomplete="email"
          aria-label="{{ 'sections.newsletter.email_placeholder' | t }}"
        >
        <button type="submit" class="section-newsletter__submit">
          {{ 'sections.newsletter.subscribe' | t }}
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "section-newsletter-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Stay in Touch",
      "label": "t:sections.newsletter.settings.heading.label"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "default": "Subscribe to receive updates, access to exclusive deals, and more.",
      "label": "t:sections.newsletter.settings.subtext.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.presets.name"
    }
  ]
}
{% endschema %}
