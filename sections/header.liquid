<style>
  .section-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition-base), border-color var(--transition-base);
  }

  .section-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-md);
  }

  /* Logo */
  .section-header__logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
  }

  .section-header__logo-image {
    max-height: 40px;
    width: auto;
  }

  /* Navigation */
  .section-header__nav {
    display: none;
  }

  @media screen and (min-width: 1024px) {
    .section-header__nav {
      display: flex;
      align-items: center;
      gap: var(--space-lg);
    }
  }

  .section-header__nav-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast);
    padding: var(--space-xs) 0;
  }

  .section-header__nav-link:hover {
    color: var(--color-accent);
  }

  /* Actions */
  .section-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .section-header__action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target);
    height: var(--touch-target);
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .section-header__action-btn:hover {
    color: var(--color-accent);
  }

  .section-header__action-btn svg {
    width: 20px;
    height: 20px;
  }

  .section-header__cart-count {
    position: absolute;
    top: 4px;
    right: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1;
    color: #FFFFFF;
    background-color: var(--color-accent);
    border-radius: 9px;
  }

  /* Theme toggle */
  .section-header__theme-toggle {
    position: relative;
  }

  /* Language selector in header */
  .section-header .language-selector__select {
    appearance: none;
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 0.375rem 1.5rem 0.375rem 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text);
    cursor: pointer;
  }

  /* Mobile menu toggle */
  .section-header__menu-toggle {
    display: inline-flex;
  }

  @media screen and (min-width: 1024px) {
    .section-header__menu-toggle {
      display: none;
    }
  }

  /* Mobile drawer */
  .section-header__drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
  }

  .section-header__drawer.is-open {
    display: block;
  }

  .section-header__drawer-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-overlay);
  }

  .section-header__drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background-color: var(--color-bg);
    padding: var(--space-lg);
    overflow-y: auto;
  }

  .section-header__drawer-close {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-bottom: var(--space-lg);
  }

  .section-header__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .section-header__drawer-link {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }
</style>

<header class="section-header" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="section-header__inner">
      {%- comment -%} Mobile menu toggle {%- endcomment -%}
      <button
        class="section-header__action-btn section-header__menu-toggle"
        aria-label="{{ 'sections.header.menu' | t }}"
        data-menu-toggle
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="section-header__logo">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: height: 80
            | image_tag:
              class: 'section-header__logo-image',
              alt: shop.name,
              loading: 'eager'
          }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>

      {%- comment -%} Desktop Navigation {%- endcomment -%}
      <nav class="section-header__nav" aria-label="{{ 'sections.header.navigation' | t }}">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="section-header__nav-link">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      {%- comment -%} Actions {%- endcomment -%}
      <div class="section-header__actions">
        {%- comment -%} Language selector {%- endcomment -%}
        {% render 'language-selector' %}

        {%- comment -%} Dark mode toggle {%- endcomment -%}
        <button
          class="section-header__action-btn section-header__theme-toggle"
          aria-label="{{ 'sections.header.theme_toggle' | t }}"
          onclick="toggleTheme()"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 8.002-4.248 1 1 0 0 0 1-1.75Z"/>
          </svg>
        </button>

        {%- comment -%} Cart {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="section-header__action-btn" style="position: relative;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="section-header__cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>

  {%- comment -%} Mobile drawer {%- endcomment -%}
  <div class="section-header__drawer" data-menu-drawer>
    <div class="section-header__drawer-overlay" data-menu-close></div>
    <div class="section-header__drawer-panel">
      <div class="section-header__drawer-close">
        <button class="section-header__action-btn" data-menu-close aria-label="{{ 'accessibility.close' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <nav class="section-header__drawer-nav" aria-label="{{ 'sections.header.navigation' | t }}">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="section-header__drawer-link">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.header.settings.logo.label"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    }
  ]
}
{% endschema %}
