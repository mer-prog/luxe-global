{
  "sections": {
    "hero": {
      "type": "hero-banner",
      "settings": {
        "hero_heading": "t:sections.hero_banner.defaults.heading",
        "hero_subtext": "t:sections.hero_banner.defaults.subtext",
        "button_text": "t:sections.hero_banner.defaults.button_text",
        "button_url": "shopify://collections/all",
        "overlay_opacity": 45
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "t:sections.featured_collection.defaults.title",
        "subtitle": "t:sections.featured_collection.defaults.subtitle",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": "4",
        "show_view_all": true
      }
    },
    "brand_story": {
      "type": "brand-story",
      "settings": {
        "heading": "t:sections.brand_story.defaults.heading",
        "text": "t:sections.brand_story.defaults.text",
        "button_text": "t:sections.brand_story.defaults.button_text",
        "image_position": "left"
      }
    },
    "faq": {
      "type": "faq",
      "blocks": {
        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "t:sections.faq.defaults.faq_1.question",
            "answer": "t:sections.faq.defaults.faq_1.answer"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "t:sections.faq.defaults.faq_2.question",
            "answer": "t:sections.faq.defaults.faq_2.answer"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "t:sections.faq.defaults.faq_3.question",
            "answer": "t:sections.faq.defaults.faq_3.answer"
          }
        }
      },
      "block_order": ["faq-1", "faq-2", "faq-3"],
      "settings": {
        "title": "t:sections.faq.defaults.title"
      }
    },
    "newsletter": {
      "type": "newsletter",
      "settings": {
        "heading": "t:sections.newsletter.defaults.heading",
        "subtext": "t:sections.newsletter.defaults.subtext"
      }
    }
  },
  "order": [
    "hero",
    "featured_collection",
    "brand_story",
    "faq",
    "newsletter"
  ]
}
